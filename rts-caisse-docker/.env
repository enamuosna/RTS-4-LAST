# =============================================================
#  RTS Caisse - Variables d'environnement PRODUCTION (HTTPS)
#  Copier ce fichier en ".env" puis remplir les valeurs
# =============================================================

# =============================================================
#  Domaine et SSL (Let's Encrypt + DuckDNS)
# =============================================================

# OBLIGATOIRE : nom de domaine public pointant vers 41.216.16.108
# Choisir un sous-domaine DuckDNS gratuit sur https://www.duckdns.org/
# Exemples : rts-caisse.duckdns.org, caisse-rts.duckdns.org
SERVER_NAME=rts-caisse.duckdns.org

# Token DuckDNS (recupere sur https://www.duckdns.org/ apres login)
# Sert au script duckdns-update.sh pour synchroniser DNS <-> IP publique
DUCKDNS_TOKEN=6e4344c2-17ce-4654-9e35-7fd93b546a8b

# OBLIGATOIRE : email de contact pour Let's Encrypt
# (utilise pour les alertes d'expiration de certificat)
LETSENCRYPT_EMAIL=ansoumane2camara@gmail.com

# Mode staging Let's Encrypt (1 = certs de TEST, 0 = certs reels)
# IMPORTANT : commencer a 1 pour tester le pipeline (limite plus large)
# puis passer a 0 quand tout fonctionne (limite : 5 certs/semaine/domaine)
LETSENCRYPT_STAGING=1

# =============================================================
#  Base de donnees PostgreSQL
# =============================================================
POSTGRES_DB=rts_caisse_db
POSTGRES_USER=postgres
# OBLIGATOIRE : mot de passe fort (16+ caracteres)
POSTGRES_PASSWORD=amc2622amc

# Port Postgres expose UNIQUEMENT en localhost (127.0.0.1) sur l'hote
# Pour acces depuis le LAN : tunnel SSH ou VPN
POSTGRES_HOST_PORT=5432

# =============================================================
#  Securite applicative
# =============================================================
# OBLIGATOIRE : cle HMAC pour signer les JWT (>= 64 caracteres Base64)
# Generer avec : openssl rand -base64 64
JWT_SECRET=8/WkAz2ZMQy9AzI1K4Mbt0fNP6QhbaMWMB4EuNxB7ThL3PC1ldJefJ7qB3cIh26TIhie7Gr/Ntyo9tYvyQ8kFQ==

# =============================================================
#  Versionning des images Docker
# =============================================================
APP_VERSION=latest
DOCKER_REGISTRY=vnsu

# =============================================================
#  Reseau interne (informations seulement)
# =============================================================
# IP privee LAN du serveur Docker  : 192.168.150.251
# IP publique WAN (vers Internet)  : 41.216.16.108
# Ports a forwarder sur le routeur : 80 et 443 -> 192.168.150.251
