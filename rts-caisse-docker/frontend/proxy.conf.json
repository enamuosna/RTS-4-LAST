{
  "_comment": "Proxy ng serve - relaie les appels /api/* vers le backend Spring Boot local. À placer dans rts-caisse-web/proxy.conf.json et référencer dans angular.json (serve.options.proxyConfig).",

  "/api": {
    "target": "http://localhost:9090",
    "secure": false,
    "changeOrigin": true,
    "logLevel": "debug"
  },
  "/v3/api-docs": {
    "target": "http://localhost:9090",
    "secure": false,
    "changeOrigin": true
  },
  "/swagger-ui": {
    "target": "http://localhost:9090",
    "secure": false,
    "changeOrigin": true
  },
  "/actuator": {
    "target": "http://localhost:9090",
    "secure": false,
    "changeOrigin": true
  }
}
