<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<!--
    Écran de connexion (authentification utilisateur).
    Logo RTS officiel centré en haut de la carte.
-->

<StackPane styleClass="login-pane" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="sn.rts.caisse.guichet.controller.LoginController">

    <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="420" spacing="14" styleClass="login-card">

        <!-- ======================== Logo RTS ========================
             Logo seul : on a retire le titre "RTS Caisse" et le subtitle
             "Guichet Radiodiffusion..." (redondants avec le logo).      -->
        <StackPane alignment="CENTER" styleClass="login-logo">
            <ImageView fitHeight="76" fitWidth="76" preserveRatio="true" smooth="true">
                <image>
                    <Image url="@rts-logo.jpg" />
                </image>
            </ImageView>
        </StackPane>

        <!-- ===================== Formulaire ===================== -->
        <VBox maxWidth="360" spacing="14">
            <VBox.margin>
                <Insets top="20" />
            </VBox.margin>

            <!-- Identifiant -->
            <VBox spacing="6">
                <Label styleClass="field-label" text="IDENTIFIANT" />
                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="text-field-with-icon">
                    <FontIcon iconLiteral="fas-user" iconSize="16" styleClass="icon-muted" />
                    <TextField fx:id="loginField" promptText="Votre identifiant" HBox.hgrow="ALWAYS" />
                </HBox>
            </VBox>

            <!-- Mot de passe -->
            <VBox spacing="6">
                <Label styleClass="field-label" text="MOT DE PASSE" />
                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="text-field-with-icon">
                    <FontIcon iconLiteral="fas-lock" iconSize="16" styleClass="icon-muted" />
                    <PasswordField fx:id="passwordField" promptText="••••••••" HBox.hgrow="ALWAYS" />
                </HBox>
            </VBox>

            <!-- Message d'erreur -->
            <Label fx:id="errorLabel" managed="false" styleClass="error-banner" visible="false" wrapText="true" />

            <!-- Bouton Se connecter -->
            <Button fx:id="loginButton" defaultButton="true" maxWidth="Infinity" onAction="#onLogin" prefHeight="46" styleClass="button, button-primary">
                <graphic>
                    <HBox alignment="CENTER" spacing="10">
                        <FontIcon iconLiteral="fas-sign-in-alt" iconSize="16" iconColor="white" />
                        <Label fx:id="loginButtonLabel" style="-fx-text-fill: white; -fx-font-weight: 600; -fx-font-size: 13.5px;" text="Se connecter" />
                    </HBox>
                </graphic>
            </Button>

            <!-- Lien « Changer de serveur » -->
            <HBox alignment="CENTER" spacing="6">
                <FontIcon iconLiteral="fas-arrow-left" iconSize="12" styleClass="icon-muted" />
                <Hyperlink onAction="#onChangerServeur" styleClass="link-discreet" text="Changer de serveur" />
            </HBox>

            <Label fx:id="versionLabel" alignment="CENTER" maxWidth="Infinity" styleClass="login-subtitle" text="v1.0.0  © RTS" />
        </VBox>

    </VBox>

</StackPane>
