<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<!--
    Dashboard caissier refondu (v3) :
    - Header : logo RTS, titre, infos caisse, badge agent, bouton Déconnexion
      (le bouton "Changer de caisse" a été retiré : un seul caissier par caisse)
    - Bandeau statut : OUVERTE/FERMÉE + solde courant + Ouvrir/Clôturer
    - Zone principale : titre "Opérations du jour" + champ de recherche
      automatique + bouton "+ Nouvelle opération"
    - Tableau trié par date décroissante (dernière opération en haut)
    - Footer : pagination (10 opérations / page) + compteur d'opérations
-->

<BorderPane prefHeight="800" prefWidth="1400" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="sn.rts.caisse.guichet.controller.CaissierController">

    <!-- ====================== HEADER ====================== -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="14" styleClass="app-header">

            <ImageView fitHeight="40" fitWidth="40" preserveRatio="true" smooth="true">
                <image>
                    <Image url="@rts-logo.jpg" />
                </image>
            </ImageView>

            <VBox spacing="2">
                <Label styleClass="app-title" text="RTS Caisse  Guichet" />
                <Label fx:id="caisseHeaderLabel" styleClass="app-subtitle" text="Aucune caisse sélectionnée" />
            </VBox>

            <Region HBox.hgrow="ALWAYS" />

            <!-- Badge agent -->
            <HBox alignment="CENTER" spacing="10" styleClass="user-badge">
                <Label fx:id="agentInitialsLabel" styleClass="agent-avatar" text="—" />
                <VBox spacing="0">
                    <Label fx:id="agentNameLabel" styleClass="user-name" text="Agent" />
                    <Label fx:id="agentRoleLabel" styleClass="user-role" text="—" />
                </VBox>
            </HBox>

            <!-- Bouton bascule thème (soleil/lune) -->
            <Button fx:id="themeToggleButton" onAction="#onToggleTheme" styleClass="button, button-ghost, button-icon">
                <graphic>
                    <FontIcon fx:id="themeToggleIcon" iconLiteral="fas-moon" iconSize="16" styleClass="icon-muted" />
                </graphic>
                <tooltip>
                    <Tooltip text="Basculer entre mode clair et sombre" />
                </tooltip>
            </Button>

            <!-- Bouton header : déconnexion uniquement -->
            <Button onAction="#onLogout" styleClass="button, button-ghost" text="Déconnexion">
                <graphic>
                    <FontIcon iconLiteral="fas-sign-out-alt" iconSize="14" styleClass="icon-muted" />
                </graphic>
            </Button>
        </HBox>
    </top>

    <!-- ====================== CENTER ====================== -->
    <center>
        <VBox spacing="20">
            <padding><Insets bottom="20" left="28" right="28" top="20" /></padding>

            <!-- ============== BANDEAU STATUT CAISSE ============== -->
            <HBox fx:id="statusBanner" alignment="CENTER_LEFT" spacing="40" styleClass="status-banner">

                <VBox spacing="4">
                    <Label styleClass="banner-title" text="STATUT DE LA CAISSE" />
                    <Label fx:id="statusLabel" styleClass="banner-value" text="—" />
                </VBox>

                <Region HBox.hgrow="ALWAYS" />

                <VBox fx:id="soldeBox" alignment="CENTER_RIGHT" spacing="4">
                    <Label styleClass="banner-title" text="SOLDE COURANT" />
                    <Label fx:id="soldeLabel" styleClass="banner-value" text="—" />
                </VBox>

                <Button fx:id="ouvrirButton" onAction="#onOuvrirCaisse" styleClass="button, button-accent" text="Ouvrir la caisse">
                    <graphic>
                        <FontIcon iconLiteral="fas-unlock-alt" iconSize="14" iconColor="#B30510" />
                    </graphic>
                </Button>

                <Button fx:id="cloturerButton" onAction="#onCloturerCaisse" styleClass="button, button-danger" text="Clôturer la caisse">
                    <graphic>
                        <FontIcon iconLiteral="fas-lock" iconSize="14" iconColor="white" />
                    </graphic>
                </Button>
            </HBox>

            <!-- ============== ZONE OPÉRATIONS DU JOUR ============== -->
            <VBox spacing="14" styleClass="card" VBox.vgrow="ALWAYS">

                <!-- Titre + recherche + bouton refresh + nouvelle opération -->
                <HBox alignment="CENTER_LEFT" spacing="14">
                    <Label styleClass="h3" text="Opérations de Caisse" />

                    <Region HBox.hgrow="ALWAYS" />

                    <!-- Champ de recherche automatique (filtre en temps réel) -->
                    <HBox alignment="CENTER_LEFT" maxWidth="320" prefWidth="320" spacing="8" styleClass="text-field-with-icon">
                        <FontIcon iconLiteral="fas-search" iconSize="14" styleClass="icon-muted" />
                        <TextField fx:id="searchField" promptText="Rechercher (n° reçu, catégorie, client, montant…)" HBox.hgrow="ALWAYS" />
                    </HBox>

                    <Button fx:id="refreshButton" onAction="#onRefresh" styleClass="button, button-icon">
                        <graphic>
                            <FontIcon iconLiteral="fas-sync-alt" iconSize="14" styleClass="icon-muted" />
                        </graphic>
                    </Button>

                    <Button fx:id="nouvelleOperationButton" defaultButton="true" onAction="#onNouvelleOperation" styleClass="button, button-primary">
                        <graphic>
                            <HBox alignment="CENTER" spacing="8">
                                <FontIcon iconLiteral="fas-plus-circle" iconSize="14" iconColor="white" />
                                <Label style="-fx-text-fill: white; -fx-font-weight: 600;" text="Nouvelle opération" />
                            </HBox>
                        </graphic>
                    </Button>
                </HBox>

                <!-- Tableau des opérations (page courante uniquement) -->
                <TableView fx:id="operationsTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colHeure" prefWidth="80" sortable="false" text="Heure" />
                        <TableColumn fx:id="colNumero" prefWidth="180" sortable="false" text="N° Reçu" />
                        <TableColumn fx:id="colType" prefWidth="110" sortable="false" text="Type" />
                        <TableColumn fx:id="colCategorie" prefWidth="220" sortable="false" text="Catégorie" />
                        <TableColumn fx:id="colClient" prefWidth="320" sortable="false" text="Client" />
                        <TableColumn fx:id="colMontant" prefWidth="160" sortable="false" text="Montant" />
                        <TableColumn fx:id="colActions" prefWidth="160" resizable="false" sortable="false" text="Actions" />
                    </columns>
                </TableView>

                <!-- Barre de pagination + compteur -->
                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="pagination-bar">

                    <Label fx:id="compteurLabel" styleClass="text-muted, text-sm" text="0 opération" />

                    <Region HBox.hgrow="ALWAYS" />

                    <Button fx:id="firstPageButton" onAction="#onPremierePage" styleClass="button, button-ghost, button-icon" text="«" />
                    <Button fx:id="prevPageButton" onAction="#onPagePrecedente" styleClass="button, button-ghost, button-icon" text="‹" />
                    <Label fx:id="pageInfoLabel" alignment="CENTER" minWidth="100" styleClass="text-muted, text-sm" text="Page 1 / 1" />
                    <Button fx:id="nextPageButton" onAction="#onPageSuivante" styleClass="button, button-ghost, button-icon" text="›" />
                    <Button fx:id="lastPageButton" onAction="#onDernierePage" styleClass="button, button-ghost, button-icon" text="»" />
                </HBox>

            </VBox>
        </VBox>
    </center>
</BorderPane>
