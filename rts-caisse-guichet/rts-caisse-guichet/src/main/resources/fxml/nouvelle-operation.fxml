<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<!--
    RTS Caisse — Modal "Nouvelle opération" (v5.2)

    v5.2 :
      - RETIRE définitivement le champ MOTIF. Le contrôleur ne
        l'utilise plus et le backend l'accepte null (migration V3
        + entity OperationCaisse.motif nullable).
    v5 :
      - AJOUTE une section BANQUE, visible uniquement quand le mode
        de paiement est CHEQUE ou VIREMENT
      - Conserve la bascule client Existant / + Nouveau de la v4
      - Conserve le ScrollPane de la v4.1
-->
<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="sn.rts.caisse.guichet.controller.NouvelleOperationController"
      styleClass="modal-root"
      prefWidth="680"  minWidth="600"  maxWidth="760"
      prefHeight="600" minHeight="460" maxHeight="780">

    <!-- ====================== HEADER MODAL ====================== -->
    <HBox styleClass="modal-header" alignment="CENTER_LEFT" spacing="14">
        <padding><Insets top="20" right="22" bottom="20" left="26"/></padding>

        <FontIcon iconLiteral="fas-plus-circle" iconSize="22" iconColor="white" />

        <VBox spacing="2" HBox.hgrow="ALWAYS">
            <Label styleClass="modal-title" text="Nouvelle opération"/>
            <Label fx:id="caisseLabel" styleClass="modal-subtitle"
                   text="Caisse sélectionnée"/>
        </VBox>

        <Button fx:id="fermerButton" styleClass="button-close"
                onAction="#onAnnuler" prefWidth="36" prefHeight="36">
            <graphic>
                <FontIcon iconLiteral="fas-times" iconSize="16" iconColor="white" />
            </graphic>
        </Button>
    </HBox>

    <!-- ====================== CORPS DU FORMULAIRE ====================== -->
    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                styleClass="modal-scroll-pane" VBox.vgrow="ALWAYS">

        <VBox spacing="18" styleClass="modal-body">
            <padding><Insets top="22" right="26" bottom="22" left="26"/></padding>

            <!-- ========== Type d'opération ========== -->
            <VBox spacing="6">
                <Label styleClass="field-label" text="TYPE D'OPÉRATION"/>
                <HBox spacing="10">
                    <fx:define>
                        <ToggleGroup fx:id="typeGroup"/>
                    </fx:define>
                    <ToggleButton fx:id="entreeToggle" text="ENCAISSEMENT"
                                  styleClass="toggle-button, entree-toggle"
                                  toggleGroup="$typeGroup"
                                  onAction="#onTypeChange"
                                  selected="true"
                                  maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                    <ToggleButton fx:id="sortieToggle" text="DÉCAISSEMENT"
                                  styleClass="toggle-button, sortie-toggle"
                                  toggleGroup="$typeGroup"
                                  onAction="#onTypeChange"
                                  maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                </HBox>
            </VBox>

            <!-- ========== Catégorie + Mode de paiement ========== -->
            <GridPane hgap="14" vgap="6">
                <columnConstraints>
                    <ColumnConstraints percentWidth="50"/>
                    <ColumnConstraints percentWidth="50"/>
                </columnConstraints>

                <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <Label styleClass="field-label" text="CATÉGORIE *"/>
                    <ComboBox fx:id="categorieCombo" maxWidth="Infinity"
                              promptText="Sélectionner une catégorie"/>
                </VBox>

                <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <Label styleClass="field-label" text="MODE DE PAIEMENT *"/>
                    <ComboBox fx:id="modePaiementCombo" maxWidth="Infinity"
                              promptText="Mode de règlement"/>
                </VBox>
            </GridPane>
            <!-- ========== Montant HT + Référence ========== -->
            <GridPane hgap="14" vgap="6">
                <columnConstraints>
                    <ColumnConstraints percentWidth="50"/>
                    <ColumnConstraints percentWidth="50"/>
                </columnConstraints>
                <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <Label styleClass="field-label" text="MONTANT HT (FCFA) *"/>
                    <TextField fx:id="montantField" promptText="ex : 150 000"/>
                </VBox>

                <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <Label styleClass="field-label" text="RÉFÉRENCE"/>
                    <TextField fx:id="referenceField"
                               promptText="N° chèque, TX Wave/OM, bordereau..."/>
                </VBox>
            </GridPane>

            <!-- ========== Timbre + Montant TTC (calculé) ========== -->
            <GridPane hgap="14" vgap="6">
                <columnConstraints>
                    <ColumnConstraints percentWidth="50"/>
                    <ColumnConstraints percentWidth="50"/>
                </columnConstraints>
                <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <Label styleClass="field-label" text="TIMBRE FISCAL (FCFA)"/>
                    <TextField fx:id="timbreField" promptText="0"/>
                </VBox>

                <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <Label styleClass="field-label" text="MONTANT TTC (calculé)"/>
                    <TextField fx:id="montantTtcField" editable="false"
                               promptText="0"
                               style="-fx-font-weight: bold;"/>
                </VBox>
            </GridPane>

            <!-- ========== Date + Heure de diffusion (OBLIGATOIRE) ==========
                 RTS est une chaine TV : toute operation de caisse doit etre
                 rattachee a un creneau de diffusion antenne (spot pub,
                 sponsoring, message). Imprime sur le recu (ligne
                 "Diffusion"). Date ET heure sont desormais obligatoires
                 cote backend (regle metier). -->
            <GridPane hgap="14" vgap="6">
                <columnConstraints>
                    <ColumnConstraints percentWidth="65"/>
                    <ColumnConstraints percentWidth="35"/>
                </columnConstraints>
                <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <Label styleClass="field-label" text="DATE DE DIFFUSION *"/>
                    <DatePicker fx:id="dateDiffusionPicker" maxWidth="Infinity"
                                promptText="JJ/MM/AAAA"/>
                </VBox>
                <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <Label styleClass="field-label" text="HEURE (HH:MM) *"/>
                    <TextField fx:id="heureDiffusionField" promptText="20:30"/>
                </VBox>
            </GridPane>

            <!-- ========== Banque (visible si CHEQUE / VIREMENT) ========== -->
            <VBox fx:id="banqueBox" spacing="6"
                  visible="false" managed="false">
                <Label styleClass="field-label" text="BANQUE ÉMETTRICE *"/>
                <ComboBox fx:id="banqueCombo" maxWidth="Infinity"
                          promptText="Sélectionner la banque (code - libellé)"/>
                <Label fx:id="banqueHintLabel"
                       styleClass="client-nouveau-hint"
                       text="Obligatoire pour les règlements par chèque ou virement."
                       wrapText="true"/>
            </VBox>

            <!-- ========== SECTION CLIENT (mode Existant / + Nouveau) ========== -->
            <VBox spacing="8" styleClass="client-section">

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label styleClass="field-label" text="CLIENT (OPTIONNEL)"/>
                    <Region HBox.hgrow="ALWAYS"/>

                    <fx:define>
                        <ToggleGroup fx:id="clientModeGroup"/>
                    </fx:define>
                    <HBox spacing="0" styleClass="client-mode-switch">
                        <ToggleButton fx:id="clientExistantToggle"
                                      text="Existant"
                                      styleClass="toggle-button, mode-switch-toggle"
                                      toggleGroup="$clientModeGroup"
                                      onAction="#onClientModeChange"
                                      selected="true"/>
                        <ToggleButton fx:id="clientNouveauToggle"
                                      text="+ Nouveau"
                                      styleClass="toggle-button, mode-switch-toggle"
                                      toggleGroup="$clientModeGroup"
                                      onAction="#onClientModeChange"/>
                    </HBox>
                </HBox>

                <VBox fx:id="clientExistantPane" spacing="4">
                    <ComboBox fx:id="clientCombo" maxWidth="Infinity"
                              editable="true" promptText="Rechercher un client..."/>
                </VBox>

                <VBox fx:id="clientNouveauPane" spacing="10"
                      visible="false" managed="false"
                      styleClass="client-nouveau-pane">

                    <VBox spacing="4">
                        <Label styleClass="field-label-sub" text="RAISON SOCIALE *"/>
                        <TextField fx:id="nouveauClientRaisonSocialeField"
                                   promptText="Nom de l'entreprise ou du particulier"/>
                    </VBox>

                    <GridPane hgap="12" vgap="4">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="55"/>
                            <ColumnConstraints percentWidth="45"/>
                        </columnConstraints>

                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label styleClass="field-label-sub" text="NINEA / RCCM / CNI"/>
                            <TextField fx:id="nouveauClientIdentifiantField"
                                       promptText="Identifiant fiscal ou pièce"/>
                        </VBox>

                        <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <Label styleClass="field-label-sub" text="TÉLÉPHONE"/>
                            <TextField fx:id="nouveauClientTelephoneField"
                                       promptText="+221 77 123 45 67"/>
                        </VBox>
                    </GridPane>

                    <VBox spacing="4">
                        <Label styleClass="field-label-sub" text="E-MAIL"/>
                        <TextField fx:id="nouveauClientEmailField"
                                   promptText="contact@exemple.sn"/>
                    </VBox>

                    <VBox spacing="4">
                        <Label styleClass="field-label-sub" text="ADRESSE"/>
                        <TextField fx:id="nouveauClientAdresseField"
                                   promptText="Avenue, ville..."/>
                    </VBox>

                    <Label fx:id="nouveauClientHintLabel"
                           styleClass="client-nouveau-hint"
                           text="Le client sera créé en base lors de l'enregistrement de l'opération."
                           wrapText="true"/>
                </VBox>
            </VBox>

            <!-- Section MOTIF retirée définitivement (v5.2) :
                 le contrôleur ne lit plus motifArea et le backend
                 traite le champ comme optionnel (migration V3). -->

        </VBox>
    </ScrollPane>

    <!-- ====================== FOOTER ====================== -->
    <HBox styleClass="modal-footer" alignment="CENTER_LEFT" spacing="12">
        <padding><Insets top="16" right="26" bottom="20" left="26"/></padding>

        <Button text="Effacer" styleClass="button, button-ghost"
                onAction="#onReset">
            <graphic>
                <FontIcon iconLiteral="fas-trash-alt" iconSize="14" styleClass="icon-muted" />
            </graphic>
        </Button>

        <Region HBox.hgrow="ALWAYS"/>

        <Button text="Annuler" styleClass="button, button-secondary"
                onAction="#onAnnuler"/>

        <Button fx:id="enregistrerButton"
                text="Enregistrer l'opération"
                styleClass="button, button-primary"
                onAction="#onEnregistrer"
                defaultButton="true">
            <graphic>
                <FontIcon iconLiteral="fas-save" iconSize="14" iconColor="white" />
            </graphic>
        </Button>
    </HBox>
</VBox>
