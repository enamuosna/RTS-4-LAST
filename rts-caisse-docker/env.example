# =============================================================
#  RTS Caisse - Variables d'environnement
#  Copier ce fichier en ".env" puis remplir les valeurs
#  → Le script scripts/init-env.ps1 le fait automatiquement
# =============================================================

# -------------------------------------------------------------
#  Base de données PostgreSQL
# -------------------------------------------------------------
POSTGRES_DB=rts_caisse_db
POSTGRES_USER=rts_user
# OBLIGATOIRE : mot de passe fort en production (16+ caractères)
POSTGRES_PASSWORD=changeme_strong_password

# Port Postgres exposé sur l'hôte (DEV uniquement, pour pgAdmin / Rider)
POSTGRES_HOST_PORT=5432

# -------------------------------------------------------------
#  Sécurité applicative
# -------------------------------------------------------------
# OBLIGATOIRE : clé HMAC pour signer les JWT (>= 64 caractères Base64)
# → Généré automatiquement par scripts/init-env.ps1
JWT_SECRET=changeme_jwt_secret_min_64_chars_base64

# -------------------------------------------------------------
#  Reverse proxy nginx (gateway)
# -------------------------------------------------------------
# Port externe sur lequel l'application est accessible
# (8080 est souvent pris par EDB Postgres / Tomcat → 8090 par défaut)
GATEWAY_PORT=8090

# Origines autorisées par CORS côté backend.
# En prod, l'API est sur la même origine (gateway) → CORS quasi inutile,
# mais on le laisse pour les tests directs depuis Swagger ou autre.
CORS_ALLOWED_ORIGINS=http://localhost:8090

# -------------------------------------------------------------
#  Versionning des images Docker
# -------------------------------------------------------------
# Tag des images publiées (ex: 1.0.0, 1.2.3, latest...)
# Utilisé par docker-compose.yml ET docker-compose.prod.yml
APP_VERSION=latest

# Namespace Docker Hub (pour build-and-push)
DOCKER_REGISTRY=vnsu

# -------------------------------------------------------------
#  pgAdmin (DEV uniquement)
# -------------------------------------------------------------
# IMPORTANT : pgAdmin valide ce champ comme un vrai email.
# Eviter ".local" (TLD reserve RFC 6762) sauf si on whiteliste
# via PGADMIN_CONFIG_ALLOW_SPECIAL_EMAIL_DOMAINS dans le compose.
PGADMIN_EMAIL=admin@rts.sn
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050
